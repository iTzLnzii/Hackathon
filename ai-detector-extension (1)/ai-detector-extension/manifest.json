{
  "manifest_version": 3,
  "name": "AI Content Detector",
  "version": "1.0.0",
  "description": "Automatically detects and blocks AI-generated content on Instagram and Facebook using your backend.",

  "permissions": [
    "storage",
    "tabs",
    "activeTab"
  ],

  "host_permissions": [
    "https://www.instagram.com/*",
    "https://www.facebook.com/*",
    "https://*.cdninstagram.com/*",
    "https://*.fbcdn.net/*",
    "http://localhost:3000/*",
    "http://localhost/*",
    "https://localhost/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://www.instagram.com/*",
        "https://www.facebook.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Content Detector",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "web_accessible_resources": [
    {
      "resources": ["icons/*.png"],
      "matches": ["https://www.instagram.com/*", "https://www.facebook.com/*"]
    }
  ]
}
